# Copy this file to .env and fill in your key to enable AI features.
# The app works fully without this — AI features degrade gracefully.
ANTHROPIC_API_KEY=

# Optional overrides
PORT=3001

# Database — leave both unset for local-only use (defaults to a local file
# at server/data/sandhya.db). Set both to point at a remote Turso database
# instead (needed for serverless hosting, e.g. Vercel).
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Password-gate auth (Phase B) — leave unset to run without a login screen.
APP_PASSWORD_HASH=
SESSION_SECRET=
